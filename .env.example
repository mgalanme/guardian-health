# === LLM ===
GROQ_API_KEY=your_groq_api_key_here

# === Observability ===
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=guardian-health

# === Neo4j ===
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# === PostgreSQL ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=guardian_health
POSTGRES_USER=guardian_health
POSTGRES_PASSWORD=your_postgres_password_here
DATABASE_URL=postgresql://guardian_health:your_password@localhost:5432/guardian_health

# === Qdrant ===
QDRANT_HOST=localhost
QDRANT_PORT=6333

# === Pinecone ===
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENV=us-east-1

# === HuggingFace ===
HF_TOKEN=your_hf_token_here

# === Vector store selector (qdrant | pinecone) ===
VECTOR_STORE=qdrant

# === FastAPI ===
API_HOST=0.0.0.0
API_PORT=8000

# === n8n ===
N8N_PORT=5678
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=your_n8n_password_here

# === Guardian specific ===
GUARDIAN_ENV=development
AUDIT_TRAIL_ENABLED=true
HITL_ENABLED=true
